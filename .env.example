# LiteLLM upstream settings for this repo's local stack.
LITELLM_UPSTREAM_MODEL=openai/gpt-5-mini
OPENAI_API_KEY=
OPENAI_API_BASE=
LITELLM_BIND_HOST=127.0.0.1
LITELLM_PORT=28789
WORKSPACE_DIR=.

# Optional for Codex -> LiteLLM auth header.
# LiteLLM simple-proxy mode often accepts any bearer value.
CUSTOM_LLM_API_KEY=dummy
