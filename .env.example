# LiteLLM upstream settings for this repo's local stack.
LITELLM_UPSTREAM_MODEL=openai/gpt-5-mini
OPENAI_API_KEY=
OPENAI_API_BASE=
LITELLM_MASTER_KEY=replace-with-a-local-master-key
POSTGRES_DB=litellm
POSTGRES_USER=litellm
POSTGRES_PASSWORD=replace-with-a-local-db-password
DATABASE_URL=postgresql://litellm:replace-with-a-local-db-password@postgres:5432/litellm
UI_USERNAME=admin
UI_PASSWORD=replace-with-a-local-ui-password
STORE_MODEL_IN_DB=True
RESPONSES_CACHE_PROXY_API_KEY=replace-with-a-local-cache-proxy-key
RESPONSES_CACHE_PROXY_INNER_BASE_URL=http://litellm:4000/v1
RESPONSES_CACHE_PROXY_INNER_MODEL=gpt-5-nano
RESPONSES_CACHE_PROXY_REDIS_URL=redis://redis:6379/0
RESPONSES_CACHE_PROXY_HISTORY_TTL_SECONDS=604800
RESPONSES_CACHE_PROXY_MODE=record
RESPONSES_CACHE_PROXY_REPLAY_MODE=replay_only
RESPONSES_CACHE_PROXY_BASE_URL=http://responses-cache-proxy:8000/v1
RESPONSES_CACHE_PROXY_REPLAY_BASE_URL=http://responses-cache-proxy-replay:8000/v1
LITELLM_BIND_HOST=127.0.0.1
LITELLM_PORT=28789
REDIS_COMMANDER_BIND_HOST=127.0.0.1
REDIS_COMMANDER_PORT=28790
WORKSPACE_DIR=.

# Codex -> LiteLLM bearer token. Set this to the same value as LITELLM_MASTER_KEY.
CUSTOM_LLM_API_KEY=replace-with-a-local-master-key
